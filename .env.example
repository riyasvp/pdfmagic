# Supabase Configuration
# Get these values from your Supabase project dashboard (Settings > API)

# Public URL (used by both client and server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key (used by client-side code - safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (used by server-side code only - NEVER expose this!)
# This key bypasses Row Level Security (RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Storage bucket name (defaults to "pdf-edits" if not set)
SUPABASE_BUCKET_NAME=pdf-edits

# Demo Mode - Set to "true" to allow server-side PDF tools without login
# In demo mode, all users get a demo user and files are stored in a shared demo folder
DEMO_MODE=false

# ==============================================================================
# GOOGLE OAUTH CONFIGURATION
# ==============================================================================
# Important: These credentials are configured in Supabase Dashboard, not here!
# 
# To enable Google OAuth:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Authentication > Providers
# 4. Enable Google provider
# 5. Add your Google OAuth credentials (see below for how to obtain)
# 6. Configure redirect URLs
#
# Note: The actual GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET go in the 
# Supabase dashboard, NOT in this .env file. This is because Supabase 
# handles the OAuth flow server-side for security.
# ==============================================================================

# Google OAuth Status (for documentation)
# Set to "true" once configured in Supabase
GOOGLE_OAUTH_CONFIGURED=false

# Google OAuth Client ID (example format - add to Supabase dashboard)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret (example - add to Supabase dashboard)
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==============================================================================
# LOCAL DEVELOPMENT SETTINGS
# ==============================================================================

# Port for local development (default: 3000)
PORT=3000

# Host for local development
HOST=0.0.0.0
