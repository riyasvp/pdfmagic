# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard

# Public keys (safe to expose in client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (NEVER expose in client bundle)
# Used for admin operations like uploading with service role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Storage Configuration
# The name of the Supabase storage bucket for PDF edits
SUPABASE_BUCKET_NAME=pdf-edits

# Optional: Custom storage path prefix
# SUPABASE_STORAGE_PATH=pdfs

# Demo Mode - Set to "true" to allow server-side PDF tools without login
# In demo mode, all users get a demo user and files are stored in a shared demo folder
# IMPORTANT: Set to "false" in production!
DEMO_MODE=false
